.version 8.5
.target sm_90a
.address_size 64

.visible .entry cluster_test()
{
	.reg .b32 %r<10>;
	.reg .b64 %rd<10>;
	.reg .pred %p<5>;
	barrier.cluster.arrive.aligned;
	barrier.cluster.wait.aligned;
	mapa.shared::cluster.u64 %rd0, %rd1, %r0;
	getctarank.shared::cluster.u32 %r1, %rd0;
	isspacep.shared::cluster %p0, %rd0;
	ret;
}
