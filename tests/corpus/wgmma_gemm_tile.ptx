.version 8.5
.target sm_90a
.address_size 64

.visible .entry wgmma_gemm_tile()
{
	.reg .b32 %r<128>;
	.reg .b64 %rd<20>;
	.reg .pred %p<10>;
	.shared .align 128 .b8 smem_a[65536];
	.shared .align 128 .b8 smem_b[65536];
	.shared .align 8 .b64 mbar_full[3];
	.shared .align 8 .b64 mbar_empty[3];
	mbarrier.init.shared.b64 [mbar_full], 1;
	mbarrier.init.shared.b64 [mbar_full+8], 1;
	mbarrier.init.shared.b64 [mbar_full+16], 1;
	mbarrier.init.shared.b64 [mbar_empty], 128;
	mbarrier.init.shared.b64 [mbar_empty+8], 128;
	mbarrier.init.shared.b64 [mbar_empty+16], 128;
	fence.mbarrier_init.release.cluster;
	setmaxnreg.inc.sync.aligned.u32 232;
	wgmma.fence.sync.aligned;
	wgmma.mma_async.sync.aligned.m64n128k16.f32.bf16.bf16 {%r0, %r1, %r2, %r3, %r4, %r5, %r6, %r7, %r8, %r9, %r10, %r11, %r12, %r13, %r14, %r15, %r16, %r17, %r18, %r19, %r20, %r21, %r22, %r23, %r24, %r25, %r26, %r27, %r28, %r29, %r30, %r31, %r32, %r33, %r34, %r35, %r36, %r37, %r38, %r39, %r40, %r41, %r42, %r43, %r44, %r45, %r46, %r47, %r48, %r49, %r50, %r51, %r52, %r53, %r54, %r55, %r56, %r57, %r58, %r59, %r60, %r61, %r62, %r63}, %rd0, %rd1, 1, 1, 1;
	wgmma.commit_group.sync.aligned;
	wgmma.wait_group.sync.aligned 0;
	setmaxnreg.dec.sync.aligned.u32 232;
	bar.sync 0;
	ret;
}
