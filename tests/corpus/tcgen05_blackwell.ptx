.version 8.7
.target sm_100a
.address_size 64

.visible .entry tcgen05_test()
{
	.reg .b32 %r<64>;
	.reg .b64 %rd<10>;
	.reg .pred %p<5>;
	.shared .align 128 .b8 smem[65536];
	.shared .align 8 .b64 mbar[2];
	.shared .align 4 .b32 tmem_addr[1];
	tcgen05.alloc.cta_group::1.sync.aligned.shared::cta.b32 [tmem_addr], 256;
	tcgen05.cp.cta_group::1.128x256b [%r0], [smem];
	tcgen05.mma.cta_group::1.kind::f16 [%r0], %rd0, %rd1, %r2, {%p0}, 1;
	tcgen05.fence::before_thread_sync;
	bar.sync 0;
	tcgen05.fence::after_thread_sync;
	tcgen05.commit.cta_group::1.mbarrier::arrive::one.shared::cta.b64 [mbar];
	tcgen05.ld.sync.aligned.16x128b.x1.b32 {%r10}, [%r0];
	tcgen05.wait::ld.sync.aligned;
	tcgen05.st.sync.aligned.16x128b.x1.b32 [%r0], {%r10};
	tcgen05.wait::st.sync.aligned;
	tcgen05.shift.cta_group::1.down [%r0];
	tcgen05.dealloc.cta_group::1.sync.aligned.b32 %r0, 256;
	tcgen05.relinquish_alloc_permit.cta_group::1.sync.aligned;
	ret;
}
