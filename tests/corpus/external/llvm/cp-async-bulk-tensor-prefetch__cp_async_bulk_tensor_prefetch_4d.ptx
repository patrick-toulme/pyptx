.version 8.5
.target sm_90a
.address_size 64

.visible .entry cp_async_bulk_tensor_prefetch_4d()
{
	.reg .b32 %r<5>;
	.reg .b64 %rd<3>;
	.reg .b16 %rs<3>;
	ld.param.b64 %rd1, [cp_async_bulk_tensor_prefetch_4d_param_1];
	ld.param.b32 %r1, [cp_async_bulk_tensor_prefetch_4d_param_2];
	ld.param.b32 %r2, [cp_async_bulk_tensor_prefetch_4d_param_3];
	ld.param.b32 %r3, [cp_async_bulk_tensor_prefetch_4d_param_4];
	ld.param.b32 %r4, [cp_async_bulk_tensor_prefetch_4d_param_5];
	ld.param.b64 %rd2, [cp_async_bulk_tensor_prefetch_4d_param_8];
	cp.async.bulk.prefetch.tensor.4d.L2.global.tile [%rd1, {%r1, %r2, %r3, %r4}];
	cp.async.bulk.prefetch.tensor.4d.L2.global.tile.L2::cache_hint [%rd1, {%r1, %r2, %r3, %r4}], %rd2;
	ld.param.b16 %rs1, [cp_async_bulk_tensor_prefetch_4d_param_6];
	ld.param.b16 %rs2, [cp_async_bulk_tensor_prefetch_4d_param_7];
	cp.async.bulk.prefetch.tensor.4d.L2.global.im2col [%rd1, {%r1, %r2, %r3, %r4}], {%rs1, %rs2};
	cp.async.bulk.prefetch.tensor.4d.L2.global.im2col.L2::cache_hint [%rd1, {%r1, %r2, %r3, %r4}], {%rs1, %rs2}, %rd2;
	ret;
}
