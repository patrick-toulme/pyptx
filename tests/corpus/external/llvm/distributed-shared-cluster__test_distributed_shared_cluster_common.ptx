.version 8.5
.target sm_90a
.address_size 64

.visible .entry test_distributed_shared_cluster_common()
{
	.reg .pred %p<3>;
	.reg .b32 %r<8>;
	.reg .b64 %rd<5>;
	ld.param.b64 %rd1, [test_distributed_shared_cluster_common_param_0];
	ld.param.b64 %rd2, [test_distributed_shared_cluster_common_param_1];
	mov.u32 %r1, %ctaid.x;
	xor.b32 %r2, %r1, 1;
	isspacep.shared::cluster %p1, %rd1;
	mapa.u64 %rd3, %rd1, %r2;
	isspacep.shared::cluster %p2, %rd3;
	mapa.shared::cluster.u64 %rd4, %rd2, %r2;
	ld.shared::cluster.b32 %r3, [%rd4];
	add.s32 %r4, %r3, 42;
	st.shared::cluster.b32 [%rd4], %r4;
	selp.b32 %r5, 1, 0, %p1;
	selp.b32 %r6, 1, 0, %p2;
	add.s32 %r7, %r5, %r6;
	st.param.b32 [func_retval0], %r7;
	ret;
}
