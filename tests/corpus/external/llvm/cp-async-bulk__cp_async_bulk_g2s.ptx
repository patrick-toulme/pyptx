.version 8.5
.target sm_90a
.address_size 64

.visible .entry cp_async_bulk_g2s()
{
	.reg .b32 %r<4>;
	.reg .b64 %rd<3>;
	.reg .b16 %rs<2>;
	ld.param.b64 %rd1, [cp_async_bulk_g2s_param_0];
	ld.param.b32 %r1, [cp_async_bulk_g2s_param_1];
	ld.param.b32 %r2, [cp_async_bulk_g2s_param_2];
	ld.param.b32 %r3, [cp_async_bulk_g2s_param_3];
	ld.param.b16 %rs1, [cp_async_bulk_g2s_param_4];
	ld.param.b64 %rd2, [cp_async_bulk_g2s_param_5];
	cp.async.bulk.shared::cluster.global.mbarrier::complete_tx::bytes [%r2], [%rd1], %r3, [%r1];
	cp.async.bulk.shared::cluster.global.mbarrier::complete_tx::bytes.L2::cache_hint [%r2], [%rd1], %r3, [%r1], %rd2;
	cp.async.bulk.shared::cluster.global.mbarrier::complete_tx::bytes.multicast::cluster [%r2], [%rd1], %r3, [%r1], %rs1;
	cp.async.bulk.shared::cluster.global.mbarrier::complete_tx::bytes.multicast::cluster.L2::cache_hint [%r2], [%rd1], %r3, [%r1], %rs1, %rd2;
	ret;
}
