.version 8.5
.target sm_100a
.address_size 64

.visible .entry tcgen05_mma_sp_fp16_cta2()
{
	.reg .pred %p<2>;
	.reg .b32 %r<5>;
	.reg .b64 %rd<3>;
	.reg .b16 %rs<3>;
	ld.param.b8 %rs1, [tcgen05_mma_sp_fp16_cta2_param_5];
	and.b16 %rs2, %rs1, 1;
	setp.ne.b16 %p1, %rs2, 0;
	ld.param.b32 %r1, [tcgen05_mma_sp_fp16_cta2_param_0];
	ld.param.b64 %rd1, [tcgen05_mma_sp_fp16_cta2_param_2];
	ld.param.b64 %rd2, [tcgen05_mma_sp_fp16_cta2_param_3];
	ld.param.b32 %r2, [tcgen05_mma_sp_fp16_cta2_param_4];
	ld.param.b32 %r3, [tcgen05_mma_sp_fp16_cta2_param_6];
	tcgen05.mma.sp.cta_group::2.kind::f16.collector::a::discard [%r1], %rd1, %rd2, [%r3], %r2, %p1;
	ld.param.b32 %r4, [tcgen05_mma_sp_fp16_cta2_param_1];
	tcgen05.mma.sp.cta_group::2.kind::f16.collector::a::discard [%r1], [%r4], %rd2, [%r3], %r2, %p1;
	tcgen05.mma.sp.cta_group::2.kind::f16.ashift.collector::a::discard [%r1], [%r4], %rd2, [%r3], %r2, %p1;
	tcgen05.mma.sp.cta_group::2.kind::f16.collector::a::lastuse [%r1], %rd1, %rd2, [%r3], %r2, %p1;
	tcgen05.mma.sp.cta_group::2.kind::f16.collector::a::lastuse [%r1], [%r4], %rd2, [%r3], %r2, %p1;
	tcgen05.mma.sp.cta_group::2.kind::f16.collector::a::fill [%r1], %rd1, %rd2, [%r3], %r2, %p1;
	tcgen05.mma.sp.cta_group::2.kind::f16.collector::a::fill [%r1], [%r4], %rd2, [%r3], %r2, %p1;
	tcgen05.mma.sp.cta_group::2.kind::f16.collector::a::use [%r1], %rd1, %rd2, [%r3], %r2, %p1;
	tcgen05.mma.sp.cta_group::2.kind::f16.collector::a::use [%r1], [%r4], %rd2, [%r3], %r2, %p1;
	ret;
}
