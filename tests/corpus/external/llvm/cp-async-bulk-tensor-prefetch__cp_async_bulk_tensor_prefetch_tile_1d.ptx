.version 8.5
.target sm_90a
.address_size 64

.visible .entry cp_async_bulk_tensor_prefetch_tile_1d()
{
	.reg .b32 %r<2>;
	.reg .b64 %rd<3>;
	ld.param.b64 %rd1, [cp_async_bulk_tensor_prefetch_tile_1d_param_0];
	ld.param.b32 %r1, [cp_async_bulk_tensor_prefetch_tile_1d_param_1];
	ld.param.b64 %rd2, [cp_async_bulk_tensor_prefetch_tile_1d_param_2];
	cp.async.bulk.prefetch.tensor.1d.L2.global.tile [%rd1, {%r1}];
	cp.async.bulk.prefetch.tensor.1d.L2.global.tile.L2::cache_hint [%rd1, {%r1}], %rd2;
	ret;
}
