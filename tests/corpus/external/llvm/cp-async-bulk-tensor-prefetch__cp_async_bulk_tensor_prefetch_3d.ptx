.version 8.5
.target sm_90a
.address_size 64

.visible .entry cp_async_bulk_tensor_prefetch_3d()
{
	.reg .b32 %r<4>;
	.reg .b64 %rd<3>;
	.reg .b16 %rs<2>;
	ld.param.b64 %rd1, [cp_async_bulk_tensor_prefetch_3d_param_1];
	ld.param.b32 %r1, [cp_async_bulk_tensor_prefetch_3d_param_2];
	ld.param.b32 %r2, [cp_async_bulk_tensor_prefetch_3d_param_3];
	ld.param.b32 %r3, [cp_async_bulk_tensor_prefetch_3d_param_4];
	ld.param.b64 %rd2, [cp_async_bulk_tensor_prefetch_3d_param_6];
	cp.async.bulk.prefetch.tensor.3d.L2.global.tile [%rd1, {%r1, %r2, %r3}];
	cp.async.bulk.prefetch.tensor.3d.L2.global.tile.L2::cache_hint [%rd1, {%r1, %r2, %r3}], %rd2;
	ld.param.b16 %rs1, [cp_async_bulk_tensor_prefetch_3d_param_5];
	cp.async.bulk.prefetch.tensor.3d.L2.global.im2col [%rd1, {%r1, %r2, %r3}], {%rs1};
	cp.async.bulk.prefetch.tensor.3d.L2.global.im2col.L2::cache_hint [%rd1, {%r1, %r2, %r3}], {%rs1}, %rd2;
	ret;
}
