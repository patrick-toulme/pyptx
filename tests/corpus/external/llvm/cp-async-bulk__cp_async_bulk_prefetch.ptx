.version 8.5
.target sm_90a
.address_size 64

.visible .entry cp_async_bulk_prefetch()
{
	.reg .b32 %r<2>;
	.reg .b64 %rd<4>;
	ld.param.b64 %rd1, [cp_async_bulk_prefetch_param_0];
	ld.param.b32 %r1, [cp_async_bulk_prefetch_param_1];
	mov.b64 %rd2, 64;
	cp.async.bulk.prefetch.L2.global.L2::cache_hint [%rd1], %r1, %rd2;
	ld.param.b64 %rd3, [cp_async_bulk_prefetch_param_2];
	cp.async.bulk.prefetch.L2.global.L2::cache_hint [%rd1], %r1, %rd3;
	cp.async.bulk.prefetch.L2.global [%rd1], %r1;
	ret;
}
