.version 8.5
.target sm_90a
.address_size 64

.visible .entry test_distributed_shared_cluster_float_atomic()
{
	.reg .b32 %r<2>;
	.reg .b64 %rd<3>;
	.reg .b16 %rs<5>;
	ld.param.b64 %rd1, [test_distributed_shared_cluster_float_atomic_param_0];
	fence.sc.sys;
	mov.b16 %rs1, 0x3C00;
	atom.acquire.sys.shared::cluster.add.noftz.f16 %rs2, [%rd1], %rs1;
	mov.b16 %rs3, 0x3F80;
	atom.acquire.sys.shared::cluster.add.noftz.bf16 %rs4, [%rd1], %rs3;
	atom.acquire.sys.shared::cluster.add.f32 %r1, [%rd1], 0f3F800000;
	atom.acquire.sys.shared::cluster.add.f64 %rd2, [%rd1], 0d3FF0000000000000;
	ret;
}
