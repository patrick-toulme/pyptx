.version 8.5
.target sm_90a
.address_size 64

.visible .entry elect_sync_twice()
{
	.reg .pred %p<3>;
	.reg .b32 %r<4>;
	.reg .b16 %rs<2>;
	ld.param.b32 %r1, [elect_sync_twice_param_0];
	elect.sync %r2|%p1, %r1;
	elect.sync %r3|%p2, %r1;
	selp.b16 %rs1, -1, 0, %p1;
	st.param.b8 [func_retval0+4], %rs1;
	st.param.b32 [func_retval0], %r2;
	ret;
}
