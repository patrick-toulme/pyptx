.version 8.5
.target sm_90a
.address_size 64

.visible .entry cp_async_bulk_tensor_s2g_tile_2d()
{
	.reg .b32 %r<4>;
	.reg .b64 %rd<3>;
	ld.param.b32 %r1, [cp_async_bulk_tensor_s2g_tile_2d_param_1];
	ld.param.b64 %rd1, [cp_async_bulk_tensor_s2g_tile_2d_param_2];
	ld.param.b32 %r2, [cp_async_bulk_tensor_s2g_tile_2d_param_3];
	ld.param.b32 %r3, [cp_async_bulk_tensor_s2g_tile_2d_param_4];
	ld.param.b64 %rd2, [cp_async_bulk_tensor_s2g_tile_2d_param_5];
	cp.async.bulk.tensor.2d.global.shared::cta.tile.bulk_group [%rd1, {%r2, %r3}], [%r1];
	cp.async.bulk.tensor.2d.global.shared::cta.tile.bulk_group.L2::cache_hint [%rd1, {%r2, %r3}], [%r1], %rd2;
	ret;
}
