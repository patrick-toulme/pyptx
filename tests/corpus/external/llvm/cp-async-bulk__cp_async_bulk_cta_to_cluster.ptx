.version 8.5
.target sm_90a
.address_size 64

.visible .entry cp_async_bulk_cta_to_cluster()
{
	.reg .b32 %r<5>;
	ld.param.b32 %r1, [cp_async_bulk_cta_to_cluster_param_0];
	ld.param.b32 %r2, [cp_async_bulk_cta_to_cluster_param_1];
	ld.param.b32 %r3, [cp_async_bulk_cta_to_cluster_param_2];
	ld.param.b32 %r4, [cp_async_bulk_cta_to_cluster_param_3];
	cp.async.bulk.shared::cluster.shared::cta.mbarrier::complete_tx::bytes [%r3], [%r1], %r4, [%r2];
	ret;
}
